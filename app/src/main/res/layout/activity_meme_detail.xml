<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_700"
        app:title="@string/detail_title"
        app:titleTextColor="@color/white"
        app:navigationIcon="?attr/actionModeCloseDrawable" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding_detail">

            <!-- Meme Image -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <ImageView
                    android:id="@+id/ivMemeDetail"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/meme_detail_image_height"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/detail_content_desc_meme"
                    android:background="@color/purple_200" />

            </androidx.cardview.widget.CardView>

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitleDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/detail_meme_title"
                android:textAppearance="@style/TextAppearance.App.HeadlineMedium" />

            <!-- Subreddit -->
            <TextView
                android:id="@+id/tvSubreddit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/detail_subreddit_placeholder"
                android:textAppearance="@style/TextAppearance.App.Caption" />

            <!-- Author -->
            <TextView
                android:id="@+id/tvAuthorDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/detail_by_author_placeholder"
                android:textAppearance="@style/TextAppearance.App.BodyMedium" />

            <!-- Ups -->
            <TextView
                android:id="@+id/tvUpsDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/detail_upvotes_placeholder"
                android:textAppearance="@style/TextAppearance.App.LabelBold" />

            <!-- NSFW -->
            <TextView
                android:id="@+id/tvNsfw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/detail_nsfw_no"
                android:textAppearance="@style/TextAppearance.App.BodyMedium" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
